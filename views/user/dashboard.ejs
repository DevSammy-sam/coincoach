<% layout('./layout/boilerplate') %>

<div class="dashboard-wrapper">
    <!-- Header Section -->
    <section class="dashboard-header py-4 py-md-5">
        <div class="container">
            <div class="row align-items-center mb-5">
                <div class="col-md-8">
                    <h1 class="dashboard-title">Welcome back, <%= currentUser.displayName %>!</h1>
                    <p class="dashboard-subtitle">
                        <%= new Date().toLocaleString('default', { month: 'long' }) %> 
                        <%= new Date().getDate() %>, <%= new Date().getFullYear() %>
                    </p>
                </div>
                <div class="col-md-4 text-md-end">
                    <a href="/transactions" class="btn btn-primary me-2">
                        <i class="fas fa-plus me-2"></i>Add Transaction
                    </a>
                    <a href="/goals" class="btn btn-secondary">
                        <i class="fas fa-target me-2"></i>Set Goal
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Main Content -->
    <div class="container py-4">
        <!-- Financial Snapshot Cards -->
        <div class="row mb-5">
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="stat-card stat-card-income">
                    <div class="stat-card-icon">
                        <i class="fas fa-arrow-down"></i>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Total Income</p>
                        <h3 class="stat-card-value">$<%= totalIncome.toFixed(2) %></h3>
                        <p class="stat-card-meta">This month</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-4">
                <div class="stat-card stat-card-expense">
                    <div class="stat-card-icon">
                        <i class="fas fa-arrow-up"></i>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Total Expenses</p>
                        <h3 class="stat-card-value">$<%= totalExpenses.toFixed(2) %></h3>
                        <p class="stat-card-meta">This month</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-4">
                <div class="stat-card stat-card-balance">
                    <div class="stat-card-icon">
                        <i class="fas fa-wallet"></i>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Net Balance</p>
                        <h3 class="stat-card-value <%= netBalance >= 0 ? 'text-success' : 'text-danger' %>">
                            $<%= netBalance.toFixed(2) %>
                        </h3>
                        <p class="stat-card-meta">Income - Expenses</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-4">
                <div class="stat-card stat-card-transactions">
                    <div class="stat-card-icon">
                        <i class="fas fa-exchange-alt"></i>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Transactions</p>
                        <h3 class="stat-card-value"><%= transactionsThisMonth %></h3>
                        <p class="stat-card-meta">This month</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Stats Row -->
        <div class="row mb-5">
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="quick-stat-card">
                    <div class="quick-stat-content">
                        <h5>Average Transaction</h5>
                        <h2>$<%= averageTransaction.toFixed(2) %></h2>
                        <p class="text-muted">Per transaction</p>
                    </div>
                    <div class="quick-stat-icon">
                        <i class="fas fa-calculator"></i>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6 mb-4">
                <div class="quick-stat-card">
                    <div class="quick-stat-content">
                        <h5>Top Category</h5>
                        <h2><%= topExpenseCategory %></h2>
                        <p class="text-muted">Highest spending</p>
                    </div>
                    <div class="quick-stat-icon">
                        <i class="fas fa-chart-pie"></i>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6 mb-4">
                <div class="quick-stat-card">
                    <div class="quick-stat-content">
                        <h5>Financial Goals</h5>
                        <h2><%= GoalCount %></h2>
                        <p class="text-muted">Active goals</p>
                    </div>
                    <div class="quick-stat-icon">
                        <i class="fas fa-bullseye"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Activity Section -->
        <div class="row">
            <div class="col-lg-8 mb-4">
                <div class="activity-card">
                    <div class="activity-header">
                        <h4>Recent Transactions</h4>
                        <a href="/transactions" class="btn-view-all">View All →</a>
                    </div>
                    <div class="activity-body">
                        <% if (recentTransactions.length > 0) { %>
                            <div class="transaction-list">
                                <% recentTransactions.forEach((transaction, index) => { %>
                                    <div class="transaction-item">
                                        <div class="transaction-info">
                                            <div class="transaction-name"><%= transaction.name || 'Unnamed' %></div>
                                            <div class="transaction-date">
                                                <%= new Date(transaction.date).toLocaleDateString('default', { 
                                                    month: 'short', 
                                                    day: 'numeric',
                                                    year: 'numeric'
                                                }) %>
                                            </div>
                                        </div>
                                        <div class="transaction-category">
                                            <%= transaction.category %>
                                        </div>
                                        <div class="transaction-amount <%= transaction.type === 'income' ? 'income' : 'expense' %>">
                                            <%= transaction.type === 'income' ? '+' : '-' %>$<%= transaction.amount.toFixed(2) %>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <div class="empty-state">
                                <i class="fas fa-inbox"></i>
                                <p>No recent transactions</p>
                                <a href="/transactions" class="btn btn-sm btn-primary">
                                    <i class="fas fa-plus me-2"></i>Add First Transaction
                                </a>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 mb-4">
                <div class="activity-card">
                    <div class="activity-header">
                        <h4>Quick Stats</h4>
                    </div>
                    <div class="quick-info">
                        <div class="quick-info-item">
                            <span class="quick-info-label">Total Transactions</span>
                            <span class="quick-info-value"><%= TransactionCount %></span>
                        </div>
                        <div class="quick-info-item">
                            <span class="quick-info-label">This Month</span>
                            <span class="quick-info-value"><%= transactionsThisMonth %></span>
                        </div>
                        <div class="quick-info-item">
                            <span class="quick-info-label">Active Goals</span>
                            <span class="quick-info-value"><%= GoalCount %></span>
                        </div>
                        <div class="quick-info-item">
                            <span class="quick-info-label">Savings Rate</span>
                            <span class="quick-info-value">
                                <%= totalIncome > 0 ? ((netBalance / totalIncome) * 100).toFixed(1) : 0 %>%
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
