<% layout('./layout/boilerplate') %>

<!-- Hero Section -->
<section class="hero-section py-5 py-md-6">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 mb-5 mb-lg-0">
                <div class="hero-content">
                    <h1 class="hero-title">Intelligent Personal Finance Management</h1>
                    <p class="hero-subtitle">CoinCoach is a comprehensive financial management platform that helps you track spending, manage bills, achieve savings goals, and build lasting financial stability through AI-powered insights and real-time analytics.</p>
                    <div class="hero-buttons d-flex flex-wrap gap-3 mt-5">
                        <a href="/register" class="btn btn-primary btn-lg">
                            <i class="fas fa-user-plus me-2"></i>Create Free Account
                        </a>
                        <a href="#features" class="btn btn-outline-secondary btn-lg">
                            <i class="fas fa-chevron-down me-2"></i>Explore Features
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hero-image-container">
                    <img src="../images/finance.jpg" alt="Financial Analytics" class="img-fluid rounded-lg shadow-lg">
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stats Section -->
<section class="stats-section py-5 py-md-6">
    <div class="container">
        <div class="stats-grid">
            <div class="stat-item">
                <div class="stat-icon-wrapper">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <h3 class="stat-value">100%</h3>
                <p class="stat-label">Data Secure</p>
                <p class="stat-description">Bank-level encryption</p>
            </div>
            <div class="stat-item">
                <div class="stat-icon-wrapper">
                    <i class="fas fa-mobile-alt"></i>
                </div>
                <h3 class="stat-value">24/7</h3>
                <p class="stat-label">Access</p>
                <p class="stat-description">Anywhere, anytime</p>
            </div>
            <div class="stat-item">
                <div class="stat-icon-wrapper">
                    <i class="fas fa-zap"></i>
                </div>
                <h3 class="stat-value">Real-Time</h3>
                <p class="stat-label">Updates</p>
                <p class="stat-description">Instant synchronization</p>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section id="features" class="features-section py-5 py-md-6">
    <div class="container">
        <div class="text-center mb-5 mb-md-6">
            <h2 class="features-title">Key Features</h2>
            <p class="features-subtitle">Everything you need to master your finances in one place</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="feature-card h-100">
                    <div class="feature-icon">
                        <i class="fas fa-exchange-alt"></i>
                    </div>
                    <h5 class="feature-title">Transaction Tracking</h5>
                    <p class="feature-text">Automatically categorize and analyze income and expenses with detailed breakdowns to identify spending patterns and opportunities for savings.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="feature-card h-100">
                    <div class="feature-icon">
                        <i class="fas fa-file-invoice-dollar"></i>
                    </div>
                    <h5 class="feature-title">Bill Management</h5>
                    <p class="feature-text">Set bill reminders, track due dates, and maintain payment history. Stay organized and avoid late fees with proactive notifications.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="feature-card h-100">
                    <div class="feature-icon">
                        <i class="fas fa-bullseye"></i>
                    </div>
                    <h5 class="feature-title">Financial Goals</h5>
                    <p class="feature-text">Define short and long-term goals with milestone tracking. Visualize progress and receive actionable recommendations to achieve your targets.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="feature-card h-100">
                    <div class="feature-icon">
                        <i class="fas fa-chart-pie"></i>
                    </div>
                    <h5 class="feature-title">AI-Powered Insights</h5>
                    <p class="feature-text">Receive personalized financial recommendations powered by machine learning. Discover optimization opportunities and financial wellness tips.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Why Choose Us Section -->
<section class="why-section py-5 py-md-6 bg-light">
    <div class="container">
        <div class="text-center mb-5 mb-md-6">
            <h2 class="section-title">Why Choose CoinCoach?</h2>
            <p class="section-subtitle">Built for simplicity, security, and success</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="why-card">
                    <div class="why-icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <h5 class="why-title">Simple & Intuitive</h5>
                    <p class="why-text">User-friendly interface designed to make financial management easy for everyone. No technical knowledge required.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="why-card">
                    <div class="why-icon">
                        <i class="fas fa-lock"></i>
                    </div>
                    <h5 class="why-title">Bank-Level Security</h5>
                    <p class="why-text">Your data is encrypted and protected with industry-standard security measures. Your privacy is our priority.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="why-card">
                    <div class="why-icon">
                        <i class="fas fa-headset"></i>
                    </div>
                    <h5 class="why-title">Dedicated Support</h5>
                    <p class="why-text">Get help when you need it. Our support team is ready to assist you with any questions or concerns.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<% if(!currentUser){ %>
    <section class="cta-section py-5 py-md-6">
        <div class="container">
            <div class="cta-content text-center">
                <h2 class="cta-title">Take Control of Your Finances Today</h2>
                <p class="cta-subtitle">Start tracking your expenses, managing bills, and achieving your financial goals with CoinCoach. It's free, simple, and takes just 2 minutes to get started.</p>
                <a href="/register" class="btn btn-primary btn-lg mt-4">
                    <i class="fas fa-user-plus me-2"></i>Create Free Account
                </a>
                <p class="cta-footer">No credit card required • Completely free to use • Your data is always yours</p>
            </div>
        </div>
    </section>
<% } %>
